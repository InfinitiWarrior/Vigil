{
  "name": "@vigil/adapter-nextjs",
  "version": "0.1.0",
  "description": "Next.js App Router adapter for Vigil (middleware, Route Handlers, and Server Components).",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vigil/core": "workspace:*",
    "next": "^14.0.0 || ^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vigil/core": "workspace:*",
    "@vigil/strategy-jwt": "workspace:*",
    "@vigil/strategy-local": "workspace:*",
    "jose": "^5.9.6",
    "next": "^16.2.10",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2"
  }
}
