{
  "name": "@vigil/adapter-fastify",
  "version": "0.1.0",
  "description": "Fastify adapter for Vigil.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vigil/core": "workspace:*",
    "fastify": "^4.28.0 || ^5.0.0"
  },
  "devDependencies": {
    "@vigil/core": "workspace:*",
    "@vigil/strategy-local": "workspace:*",
    "@vigil/strategy-jwt": "workspace:*",
    "@types/node": "^22.10.0",
    "fastify": "^5.0.1",
    "jose": "^5.9.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
