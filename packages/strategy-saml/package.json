{
  "name": "@vigil/strategy-saml",
  "version": "0.1.0",
  "description": "SAML 2.0 authentication strategy for Vigil (enterprise SSO).",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0"
  },
  "peerDependencies": {
    "@vigil/core": "workspace:*"
  },
  "devDependencies": {
    "@vigil/core": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
