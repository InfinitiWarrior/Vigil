{
  "name": "@vigil/adapter-koa",
  "version": "0.1.0",
  "description": "Koa middleware adapter for Vigil.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vigil/core": "workspace:*",
    "koa": "^2.14.0 || ^3.0.0"
  },
  "devDependencies": {
    "@koa/router": "^15.7.0",
    "@types/koa": "^3.0.3",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.3",
    "@vigil/core": "workspace:*",
    "@vigil/strategy-jwt": "workspace:*",
    "@vigil/strategy-local": "workspace:*",
    "jose": "^5.9.6",
    "koa": "^3.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
